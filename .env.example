# Atlas configuration — copy to .env and edit. All values are optional in demo mode.
#
# ─── Run mode ────────────────────────────────────────────────────────────────
# Demo mode (default) is fully deterministic and offline: no API keys, no cost.
# The Extract and Verify steps run as deterministic logic behind a clean
# interface. To wire real Claude later, implement the documented seam in
# src/engine/extract.ts and src/engine/verify.ts.
ATLAS_RUN_MODE=demo            # demo | live   (only "demo" is implemented in this build)

# ─── Live-Claude seam (NOT used in demo mode) ───────────────────────────────
# When live mode is implemented, the worker that extracts and the verifier that
# grades MUST be different models — the "worker never grades itself" rule.
# ANTHROPIC_API_KEY=sk-ant-...
# ATLAS_WORKER_MODEL=claude-opus-4-8
# ATLAS_VERIFIER_MODEL=claude-sonnet-4-6
# VOYAGE_API_KEY=...           # optional embeddings provider (Anthropic has no native embeddings API)

# ─── MCP transcript source ──────────────────────────────────────────────────
# Default: spawn the bundled mock Great Question MCP server over stdio.
# To point at the real Great Question MCP once you have access, set the URL and
# auth here — see src/providers/greatquestion.md. (Real server: OAuth 2.1/PKCE.)
# ATLAS_MCP_URL=https://greatquestion.co/api/mcp/v1

# ─── Saturation defaults (overridable per run via CLI flags) ────────────────
ATLAS_NOVELTY_THRESHOLD=0.15   # novelty below this counts toward saturation
ATLAS_K_CONSECUTIVE=3          # k consecutive low-novelty sessions => saturated
ATLAS_QUALITY_FLOOR=0.6        # verifier faithfulness below this => quality_halt
ATLAS_BUDGET_CAP=100000        # USD cap per run (high => effectively uncapped in demo)
ATLAS_COST_PER_SESSION=300     # estimated incentive+recruiting+time cost per session

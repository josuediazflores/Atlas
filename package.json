{
  "name": "atlas-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Atlas — an autonomous research-synthesis loop that knows when research is done. Detects qualitative saturation over interview transcripts fetched through Great Question's MCP.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "atlas": "./src/cli.ts"
  },
  "scripts": {
    "mcp": "tsx src/mcp/server.ts",
    "dashboard": "tsx src/server.ts",
    "demo": "tsx src/cli.ts run --study pricing-study",
    "run": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
